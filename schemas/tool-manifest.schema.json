{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tools.domain.xxx/schemas/tool-manifest.schema.json",
  "title": "ToolManifest",
  "type": "object",
  "required": [
    "id",
    "slug",
    "name",
    "description",
    "tags",
    "version",
    "execution_mode",
    "input_schema",
    "output_schema"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "execution_mode": {
      "type": "string",
      "enum": ["client-wasm", "server-api", "hybrid"]
    },
    "input_schema": {
      "type": "string"
    },
    "output_schema": {
      "type": "string"
    },
    "wasm_entry": {
      "type": "string"
    },
    "api_endpoint": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
